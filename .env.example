# Server
PORT=3000
BASE_URL=https://your-gateway.com

# 钉钉应用凭据
DINGTALK_APP_KEY=dingXXXXXX
DINGTALK_APP_SECRET=your_app_secret

# 钉钉 OAuth
DINGTALK_AUTH_URL=https://login.dingtalk.com/oauth2/auth
DINGTALK_TOKEN_URL=https://api.dingtalk.com/v1.0/oauth2/userAccessToken
DINGTALK_CALLBACK_PATH=/dingtalk/callback

# MCP OAuth (自身作为 Auth Server)
MCP_TOKEN_EXPIRY=3600
MCP_REFRESH_EXPIRY=2592000
MCP_CODE_EXPIRY=300

# Quick 预分配 Client
QUICK_CLIENT_ID=amazon_quick_001
QUICK_CLIENT_SECRET=
QUICK_REDIRECT_URI=https://quick.aws.com/sn/oauthcallback

# 存储驱动: memory（本地开发）| dynamo（生产）
STORAGE_DRIVER=memory

# AWS 配置（storage=dynamo 时生效）
AWS_REGION=ap-southeast-1

# DynamoDB 配置
DYNAMO_TABLE_NAME=dingtalk-mcp-gateway
# 本地连 DynamoDB Local 时填写，例如 http://localhost:8000；生产留空
DYNAMO_ENDPOINT=

# KMS 加密（敏感字段加密用）。留空则不加密（仅限本地开发）
KMS_KEY_ID=

# MCP 聚合网关配置
# 启用的钉钉 server（逗号分隔，留空=全部 15 个）
# 可选: bot,report,aitable,doc,wiki,contact,calendar,todo,sheet,group,drive,oa,mail,teambition,live
MCP_ENABLED_SERVERS=
# 工具列表全局缓存 TTL（秒），默认 600
MCP_TOOLS_CACHE_TTL=600

# 存储（旧版 Redis 预留，当前未使用）
REDIS_URL=
